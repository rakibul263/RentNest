    {
      "key": "base_url",
      "value": "https://rentnest-api.vercel.app",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "propertyId",
      "value": "",
      "type": "string"
    },
