          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n  \"success\": true,\n  \"message\": \"User fetched successfully\",\n  \"data\": {\n    \"id\": \"uuid\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"role\": \"tenant\",\n    \"phone\": \"+1234567890\",\n    \"isBanned\": false,\n    \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Error - Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [],
              "body": "{\n  \"success\": false,\n  \"message\": \"Authentication required\"\n}"
            }
          ]
        }
      ],
      "description": "Authentication endpoints. Register a new account or login to receive a JWT token. The token is automatically saved to the `token` variable for use in other requests."
    },
